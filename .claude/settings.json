{
  "permissions": {
    "allow": [
      "Bash(git checkout:*)",
      "Bash(npm run format:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run build:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npx playwright:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [ -n \"$f\" ] && npm run format -- \"$f\"; } 2>/dev/null || true",
            "statusMessage": "フォーマット中..."
          }
        ]
      }
    ]
  }
}
