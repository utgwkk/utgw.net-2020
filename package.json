{
  "name": "utgw.net-2020",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "run-p dev:server dev:css",
    "dev:server": "vite",
    "dev:css": "npx @tailwindcss/cli -i styles/input.css -o public/styles/main.css --watch",
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "deploy": "run-s build deploy:statics deploy:lambda",
    "deploy:lambda": "lambroll deploy --src=./dist",
    "deploy:statics": "./script/deploy-statics.sh"
  },
  "dependencies": {
    "@hono/vite-dev-server": "^0.26.0",
    "hono": "^4.12.21",
    "honox": "^0.1.56",
    "node-html-parser": "^7.1.0",
    "pino": "^10.3.1",
    "rss-parser": "^3.13.0",
    "vite": "^8.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/cli": "^4.3.0",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "msw": "^2.14.6",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3"
  }
}
