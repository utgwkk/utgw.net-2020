{
  "name": "utgw.net-2020",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "run-p dev:server dev:css",
    "dev:server": "tsx watch src/index.tsx",
    "dev:css": "npx @tailwindcss/cli -i styles/input.css -o public/styles/main.css --watch",
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "deploy": "run-s build deploy:statics deploy:lambda",
    "deploy:lambda": "lambroll deploy --src=./dist",
    "deploy:statics": "./script/deploy-statics.sh"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "hono": "^4.7.11",
    "node-html-parser": "^7.1.0",
    "pino": "^10.3.1",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.3",
    "typescript": "^6.0.2"
  }
}
