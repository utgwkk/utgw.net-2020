{
  "name": "utgw.net-2020",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "run-p dev:server dev:css",
    "dev:server": "tsx watch src/index.tsx",
    "dev:css": "npx @tailwindcss/cli -i styles/input.css -o public/styles/main.css --watch",
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "deploy": "run-s build deploy:statics deploy:lambda",
    "deploy:lambda": "lambroll deploy --src=./dist",
    "deploy:statics": "./script/deploy-statics.sh"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "hono": "^4.12.27",
    "node-html-parser": "^8.0.4",
    "pino": "^10.3.1",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/cli": "^4.3.1",
    "@types/node": "^26.0.1",
    "esbuild": "^0.28.1",
    "msw": "^2.14.6",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
